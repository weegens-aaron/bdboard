{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/packages/jscpd/schemas/jscpd.json",
  "min-tokens": 50,
  "threshold": 0.5,
  "gitignore": true,
  "absolute": false,
  "reporters": ["consoleFull"],
  "ignore": [
    "**/node_modules/**",
    "**/.venv/**",
    "**/static/**"
  ],
  "pattern": "src/**/*.{py,html}"
}
